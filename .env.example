# --- MongoDB (Atlas style: DATABASE holds a <PASSWORD> placeholder) ---
DATABASE=mongodb+srv://USER:<PASSWORD>@cluster0.xxxxx.mongodb.net/safra?retryWrites=true&w=majority&appName=Cluster0
DATABASE_PASSWORD=your-db-password
# Alternatively use a full URI directly (overrides DATABASE):
# MONGODB_URI=mongodb://127.0.0.1:27017/safra

PORT=5000

# Secret used to sign JWT login tokens
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Optional shortcut admin token (header: x-admin-token) for manager-only actions / export
ADMIN_TOKEN=safra-admin-CHANGE-ME

# Restrict CORS to specific origins in production (comma separated). Empty = allow all.
# CLIENT_ORIGIN=https://your-domain.com

# Path to the folder holding the source Excel files (defaults to repo root)
# DATA_DIR=../
